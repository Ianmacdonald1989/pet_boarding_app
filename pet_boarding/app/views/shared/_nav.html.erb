<%# current path for active nav link %>
<% path = request.path %>
<header class="app-header">
  <div class="app-header__inner">
    <%= link_to root_path, class: "app-brand" do %>
      <span class="app-brand__icon" aria-hidden="true">🐾</span>
      <span>Pet Boarding</span>
    <% end %>
    <nav class="app-nav" aria-label="Main">
      <%= link_to "Dashboard", root_path, class: (path == "/" || path == "/dashboard") ? "is-active" : nil %>
      <%= link_to "All bookings", bookings_path, class: path.start_with?("/bookings") && path == "/bookings" ? "is-active" : nil %>
      <%= link_to "New booking", new_booking_path, class: path == "/bookings/new" ? "is-active" : nil %>
    </nav>
  </div>
</header>
