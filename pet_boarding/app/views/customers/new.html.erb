<% content_for :title, "New customer — Pet Boarding" %>

<header class="page-header">
  <h1>New customer</h1>
  <p class="page-header__meta">Add a customer so you can create bookings for them.</p>
</header>

<section class="card form-card">
  <div class="card__body card__body--padded">
    <%= render "form", customer: @customer, return_to: @return_to %>
  </div>
</section>

<div class="btn-row">
  <% if @return_to.present? %>
    <%= link_to "Back", @return_to, class: "btn btn--secondary" %>
  <% else %>
    <%= link_to "Back to customers", customers_path, class: "btn btn--secondary" %>
  <% end %>
</div>

