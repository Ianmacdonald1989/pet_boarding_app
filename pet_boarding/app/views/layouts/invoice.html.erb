<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Invoice — Pet Boarding</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", media: "all" %>
    <style>
      .invoice-wrap { max-width: 820px; margin: 0 auto; padding: 2rem 1.25rem; }
      .invoice-header { display:flex; align-items:flex-start; justify-content:space-between; gap:1rem; flex-wrap:wrap; margin-bottom:1.5rem; }
      .invoice-title { margin:0; font-size:1.5rem; }
      .invoice-meta { color: var(--color-text-muted); font-size:0.95rem; }
      .invoice-actions { display:flex; gap:0.5rem; flex-wrap:wrap; }
      @media print {
        .invoice-actions { display:none !important; }
        .app-header { display:none !important; }
        body { background: #fff; }
        .card { box-shadow:none; }
      }
    </style>
  </head>
  <body>
    <div class="invoice-wrap">
      <%= yield %>
    </div>
  </body>
</html>

