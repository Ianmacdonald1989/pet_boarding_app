<%= form_with(model: booking, class: "booking-form", data: { availability_root: true }) do |form| %>
  <% if booking.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(booking.errors.count, "issue") %> to fix before saving</h2>
      <ul>
        <% booking.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <h3 class="form-section-title">Booking</h3>

  <div class="form-group">
    <%= form.label :customer_id, "Customer", class: "form-label" %>
    <%= form.collection_select :customer_id, @customers, :id, :full_name, { prompt: "Select a customer" }, { class: "form-input" } %>
  </div>

  <div class="form-group">
    <%= form.label :start_date, class: "form-label" %>
    <%= form.date_field :start_date, class: "form-input", data: { availability_start: true } %>
  </div>

  <div class="form-group">
    <%= form.label :end_date, class: "form-label" %>
    <%= form.date_field :end_date, class: "form-input", data: { availability_end: true } %>
  </div>

  <section class="card" style="margin-top: 0.75rem; box-shadow: var(--shadow-sm);">
    <div class="card__header">
      <h3 class="card__title">Availability</h3>
    </div>
    <div class="card__body">
      <div class="card__body card__body--padded" style="padding-top: 0.85rem;">
        <p class="page-header__meta" data-availability-status>Choose start and end dates to see cage availability.</p>
      </div>
      <div class="table-wrap">
        <table class="data-table">
          <thead>
            <tr>
              <th scope="col">Size</th>
              <th scope="col">Total</th>
              <th scope="col">Booked</th>
              <th scope="col">Available</th>
            </tr>
          </thead>
          <tbody data-availability-body></tbody>
        </table>
      </div>
    </div>
  </section>

  <div class="form-group">
    <%= form.label :cage_size, "Required cage size", class: "form-label" %>
    <%= form.text_field :cage_size, value: booking.cage_size, disabled: true, class: "form-input" %>
    <p class="form-hint">Computed from the pets below (guinea pig, dog, cat, hamster rules).</p>
  </div>

  <h3 class="form-section-title">Pets on this stay</h3>

  <%= form.fields_for :pets do |pet_fields| %>
    <div class="pet-card">
      <div class="pet-card__inner">
        <div class="form-group">
          <%= pet_fields.label :pet_type, "Pet type", class: "form-label" %>
          <%= pet_fields.text_field :pet_type, placeholder: "e.g. guinea pig, dog, cat, hamster", class: "form-input" %>
        </div>
        <div class="form-group">
          <%= pet_fields.label :pet_size, "Size (for dogs)", class: "form-label" %>
          <%= pet_fields.text_field :pet_size, placeholder: "e.g. large", class: "form-input" %>
        </div>
        <div class="form-group">
          <%= pet_fields.label :quantity, class: "form-label" %>
          <%= pet_fields.number_field :quantity, min: 1, class: "form-input" %>
        </div>
      </div>
    </div>
  <% end %>

  <div class="form-actions">
    <%= form.submit booking.persisted? ? "Save changes" : "Create booking", class: nil %>
  </div>
<% end %>
