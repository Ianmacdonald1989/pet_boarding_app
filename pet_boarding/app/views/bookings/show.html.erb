<% content_for :title, "Booking ##{@booking.id} — Pet Boarding" %>

<header class="page-header">
  <h1>Booking details</h1>
  <p class="page-header__meta">Customer stay and pet summary.</p>
</header>

<section class="card">
  <div class="card__body card__body--padded">
    <ul class="detail-list">
      <li>
        <span class="detail-label">Customer</span>
        <span class="detail-value"><%= @booking.customer&.full_name || "Customer ##{@booking.customer_id}" %></span>
      </li>
      <li>
        <span class="detail-label">Stay</span>
        <span class="detail-value"><%= l @booking.start_date %> — <%= l @booking.end_date %></span>
      </li>
      <li>
        <span class="detail-label">Required cage</span>
        <span class="detail-value"><span class="<%= cage_badge_class(@booking.cage_size) %>"><%= @booking.cage_size %></span></span>
      </li>
      <li>
        <span class="detail-label">Pets</span>
        <span class="detail-value"><%= pets_summary(@booking) %></span>
      </li>
    </ul>
  </div>
</section>

<div class="btn-row">
  <%= link_to "Edit booking", edit_booking_path(@booking), class: "btn btn--primary" %>
  <%= link_to "All bookings", bookings_path, class: "btn btn--secondary" %>
  <%= link_to "Dashboard", root_path, class: "btn btn--ghost" %>
</div>
