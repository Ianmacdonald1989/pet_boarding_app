source "https://rubygems.org"

# Rails is installed locally into this project (see `vendor/bundle`) so the app
# can be built without installing gems system-wide.
gem "rails", "~> 6.1.7", ">= 6.1.7.10"

# Ruby 2.6 ships with logger as a default gem. Bundler 1.x can get confused if a
# newer logger gem is pulled in, so we pin it to the default version.
gem "logger", "1.3.0"

