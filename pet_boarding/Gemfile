ruby '3.1.4'

# Bundle edge Rails instead: gem 'rails', github: 'rails/rails', branch: 'main'
gem 'rails', '~> 6.1.7', '>= 6.1.7.10'

# `logger` is part of Ruby stdlib; no need to pin it on Ruby 3.x.
